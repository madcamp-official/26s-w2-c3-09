[Unit]
Description=MOUSEKEEPER PostgreSQL protected local backup
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
User=root
Environment=MOUSEKEEPER_BACKUP_RETENTION_DAYS=7
ExecStart=/usr/local/sbin/mousekeeper-backup-postgres
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/var/backups/mousekeeper
NoNewPrivileges=true
RestrictAddressFamilies=AF_UNIX
