[Unit]
Description=HOUSEMOUSE PostgreSQL protected local backup
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
User=root
Environment=HOUSEMOUSE_BACKUP_RETENTION_DAYS=7
ExecStart=/usr/local/sbin/housemouse-backup-postgres
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/var/backups/housemouse
NoNewPrivileges=true
RestrictAddressFamilies=AF_UNIX
