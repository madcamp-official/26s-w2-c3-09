{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mousekeeper.app/contracts/events/event-envelope.schema.json",
  "title": "MOUSEKEEPER EventEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventType", "schemaVersion", "correlationId", "aggregateType", "aggregateId", "deviceId", "roomId", "sequence", "occurredAt", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "minLength": 1, "maxLength": 100 },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "correlationId": { "type": "string", "format": "uuid" },
    "aggregateType": { "type": "string", "minLength": 1, "maxLength": 50 },
    "aggregateId": { "type": "string", "format": "uuid" },
    "deviceId": { "type": ["string", "null"], "format": "uuid" },
    "roomId": { "type": ["string", "null"], "format": "uuid" },
    "sequence": { "type": "integer", "minimum": 0 },
    "occurredAt": { "type": "string", "format": "date-time" },
    "payload": { "type": "object" }
  }
}
