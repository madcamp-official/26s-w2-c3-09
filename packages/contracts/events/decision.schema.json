{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://housemouse.local/contracts/events/decision.schema.json",
  "title": "DecisionBatch",
  "description": "User decisions for a proposal batch. Approval allows the desktop to run precondition checks; it is not a bypass for local safety validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decisionBatchId",
    "proposalBatchId",
    "roomId",
    "deviceId",
    "schemaVersion",
    "decidedByUserId",
    "decidedAt",
    "decisions"
  ],
  "properties": {
    "decisionBatchId": { "type": "string", "format": "uuid" },
    "proposalBatchId": { "type": "string", "format": "uuid" },
    "roomId": { "type": "string", "format": "uuid" },
    "deviceId": { "type": "string", "format": "uuid" },
    "schemaVersion": { "type": "integer", "const": 1 },
    "decidedByUserId": { "type": "string", "format": "uuid" },
    "decidedAt": { "type": "string", "format": "date-time" },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": { "$ref": "#/$defs/DecisionEntry" }
    }
  },
  "$defs": {
    "ProposalId": {
      "type": "string",
      "pattern": "^[a-z_]+:[0-9a-f]{16}$"
    },
    "DecisionEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proposalId", "decision"],
      "properties": {
        "proposalId": { "$ref": "#/$defs/ProposalId" },
        "decision": {
          "type": "string",
          "enum": ["approved", "rejected"]
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "decision": { "const": "rejected" } },
            "required": ["decision"]
          },
          "then": { "required": ["reason"] }
        }
      ]
    }
  }
}
