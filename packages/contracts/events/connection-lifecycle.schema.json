{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mousekeeper.app/contracts/events/connection-lifecycle.schema.json",
  "title": "MouseKeeper connection lifecycle payload",
  "oneOf": [
    { "$ref": "#/$defs/DevicePaired" },
    { "$ref": "#/$defs/DeviceRevoked" },
    { "$ref": "#/$defs/RoomRemoved" }
  ],
  "$defs": {
    "DevicePaired": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deviceId", "status"],
      "properties": {
        "deviceId": { "type": "string", "format": "uuid" },
        "status": { "const": "ACTIVE" }
      }
    },
    "DeviceRevoked": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deviceId", "status"],
      "properties": {
        "deviceId": { "type": "string", "format": "uuid" },
        "status": { "const": "REVOKED" }
      }
    },
    "RoomRemoved": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roomId", "status"],
      "properties": {
        "roomId": { "type": "string", "format": "uuid" },
        "status": { "const": "REMOVED" }
      }
    }
  }
}
